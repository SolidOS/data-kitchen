# omp prefs choice lists — the subset of solid-web-components/data/ui-vocab.ttl
# that omp's settings form enumerates. Imported by omp-settings.shacl via
# owl:imports so sol-form's sh:class dropdowns can list the instances.
# Kept local (rather than cross-importing swc) so the shape resolves from
# omp's own served tree. Do not invent terms — these mirror ui-vocab.ttl.

@prefix ui:   <http://www.w3.org/ns/ui#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ui:ColorScheme a rdfs:Class ; rdfs:label "Color scheme" .
ui:LightColorScheme a ui:ColorScheme ; rdfs:label "Light" .
ui:DarkColorScheme  a ui:ColorScheme ; rdfs:label "Dark"  .

ui:FontSize a rdfs:Class ; rdfs:label "Font size" .
ui:SmallFont  a ui:FontSize ; rdfs:label "Small"  .
ui:MediumFont a ui:FontSize ; rdfs:label "Medium" .
ui:LargeFont  a ui:FontSize ; rdfs:label "Large"  .
