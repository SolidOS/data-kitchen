app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# --- dk-pod generated / downloaded artifacts (reproducible, not committed) ---
# The Node project bundle is assembled by tool/prepare-node-project.sh from the
# repo's pivot server + nodejs-src/ (run it before `flutter build`).
/android/app/src/main/assets/nodejs-project/
# Tarball cache for the 245MB CSS node_modules (rebuilt by prepare).
/.nmz-cache.nmz
# The nodejs-mobile prebuilt (libnode.so ~116MB + headers) — fetch with
# tool/fetch-libnode.sh (see README).
/third_party/node_flutter/android/libnode/
# Native build intermediates of the vendored node_flutter plugin.
/third_party/node_flutter/android/.cxx/
