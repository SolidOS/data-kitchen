@prefix : <#>.
@prefix acl: <http://www.w3.org/ns/auth/acl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix schema: <http://schema.org/>.
@prefix ui: <http://www.w3.org/ns/ui#>.

:Bar
    a ui:Menu;
    ui:label "actions";
    ui:orientation ui:Horizontal;
    ui:parts ( :bar-search :bar-calendar ).
:bar-calendar
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-calendar" ],
            [
                schema:name "source";
                schema:value "./plugins/calendar/calendar-settings.ttl#All"
            ],
        [ schema:name "title"; schema:value "Calendar" ];
    ui:label "Calendar";
    ui:name "dk-calendar-popout".
:bar-fontsize
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-fontsize" ],
        [ schema:name "data-handler"; schema:value "cycleFontSize" ],
        [ schema:name "title"; schema:value "Text size" ];
    ui:label "A";
    ui:name "sol-button".
:bar-login
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-sollogin" ],
            [
                schema:name "issuers";
                schema:value
                    "https://solidcommunity.net,https://solidweb.me,https://solidweb.org,https://login.inrupt.com"
            ],
        [ schema:name "mode"; schema:value "popup" ],
            [
                schema:name "popup-callback";
                schema:value "node_modules/podz/popup-auth-callback.html"
            ];
    ui:label "Sign in";
    ui:name "sol-login".
:bar-search
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-search" ],
            [
                schema:name "source";
                schema:value
                "./plugins/search/search-engines.ttl#SearchEngines"
            ],
        [ schema:name "title"; schema:value "Search" ];
    ui:label "Search";
    ui:name "sol-search".
:bar-settings
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-settings-launch" ],
        [ schema:name "data-handler"; schema:value "sol-include" ],
        [ schema:name "inline"; schema:value "" ],
        [ schema:name "source"; schema:value "./pages/settings.html" ],
        [ schema:name "title"; schema:value "Settings" ],
        [ schema:name "trusted"; schema:value "" ];
    ui:label "⚙";
    ui:name "sol-button".
:bar-theme
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-theme" ],
        [ schema:name "data-handler"; schema:value "toggleTheme" ],
        [ schema:name "title"; schema:value "Toggle light / dark" ];
    ui:label "🌙";
    ui:name "sol-button".
:Chrome
    a ui:Menu;
    ui:label "chrome";
    ui:parts ( :chrome-help :chrome-menu :chrome-login ).
:chrome-help
    a ui:Component;
    rdfs:comment
        "Help — opens ./help/dk.html (or ./help/dk-owner.html when signed in) in a trusted inline overlay.";
    ui:attribute
        [ schema:name "aria-label"; schema:value "Help" ],
        [ schema:name "class"; schema:value "omp-help-launch" ],
        [ schema:name "data-handler"; schema:value "sol-include" ],
        [ schema:name "if-logged-in"; schema:value "./help/dk-owner.html" ],
        [ schema:name "inline"; schema:value "" ],
        [ schema:name "source"; schema:value "./help/dk.html" ],
        [ schema:name "title"; schema:value "Help" ],
        [ schema:name "trusted"; schema:value "" ];
    ui:label "?";
    ui:name "sol-button".
:chrome-login
    a ui:Component;
    rdfs:comment
        "Sign-in — hidden until a flow needs it; sol-login surfaces itself with [active] for the duration (see dk-chrome.css).";
    ui:attribute
        [ schema:name "class"; schema:value "omp-sollogin" ],
            [
                schema:name "issuers";
                schema:value
                    "https://solidcommunity.net,https://solidweb.me,https://solidweb.org,https://login.inrupt.com"
            ],
        [ schema:name "mode"; schema:value "popup" ],
            [
                schema:name "popup-callback";
                schema:value "node_modules/podz/popup-auth-callback.html"
            ];
    ui:label "Sign in";
    ui:name "sol-login".
:chrome-menu
    a ui:Component;
    rdfs:comment
        "☰ menu — items live in data/menu.ttl#More (Customize, Settings, Sign in, and owner commands). Component items open in a modal.";
    ui:attribute
        [ schema:name "aria-label"; schema:value "Menu" ],
        [ schema:name "class"; schema:value "omp-more" ],
        [ schema:name "label"; schema:value "☰" ],
        [ schema:name "source"; schema:value "./data/menu.ttl#More" ],
        [ schema:name "title"; schema:value "Menu" ],
        [ schema:name "data-settings-skip"; schema:value "" ];
    ui:label "Menu";
    ui:name "sol-dropdown-button";
    ui:region ui:Modal.
:Dev-Tools
    a ui:Component;
    ui:attribute
        [ schema:name "id"; schema:value "panel-dev-tools" ],
            [
                schema:name "source";
                schema:value "./plugins/dev-tools/dev-tools.html"
            ],
        [ schema:name "trusted"; schema:value "" ];
    ui:label "🛠 Dev Tools";
    ui:name "sol-include".
:item
    a ui:Menu;
    ui:label "Solid";
    ui:parts
            ( :Solid-FAQ-2 :Solid-Website :Tag-Explainer-2 :Solid-Catalog-2
            :Solid-Glossary-3 ).
:JSON-LD-Playground
    a ui:Link;
    ui:href "https://json-ld.github.io/json-ld.org/playground/";
    ui:icon "🧩";
    ui:label "JSON-LD Playground";
    ui:region ui:Tab.
:JSON-LD-Playground-2
    a ui:Link;
    ui:href "https://json-ld.github.io/json-ld.org/playground/";
    ui:icon "🧩";
    ui:label "JSON-LD Playground";
    ui:region ui:Tab.
:panel-customize
    a ui:Component;
    acl:mode acl:Write;
    ui:attribute
        [ schema:name "id"; schema:value "panel-customize" ],
            [
                schema:name "source";
                schema:value "./plugins/customize/dk-customize.html"
            ],
        [ schema:name "trusted"; schema:value "" ];
    ui:label "🎛 Customize";
    ui:name "sol-include".
:panel-dev-tools
    a ui:Menu;
    ui:label "🛠 Dev Tools";
    ui:parts
            ( :Dev-Tools :RDF-Validator :SHACL-Playground :JSON-LD-Playground-2
            :SPARQL-Playground ).
:panel-home
    a ui:Component;
    ui:attribute
        [ schema:name "id"; schema:value "panel-home" ],
        [ schema:name "source"; schema:value "./plugins/home/home.html" ],
        [ schema:name "trusted"; schema:value "" ];
    ui:label "🏠 Home";
    ui:name "sol-include".
:panel-images
    a ui:Component;
    ui:attribute
        [ schema:name "id"; schema:value "panel-images" ],
            [
                schema:name "source";
                schema:value
                    "./plugins/omp-images/libraries/wikimedia_images/images.ttl#Images"
            ];
    ui:label "🖼 Images";
    ui:name "omp-images".
:panel-movies
    a ui:Component;
    ui:attribute
        [ schema:name "defer"; schema:value "" ],
        [ schema:name "favourites-only"; schema:value "" ],
        [ schema:name "id"; schema:value "panel-movies" ],
            [
                schema:name "source";
                schema:value
                    "./plugins/ia-player/libraries/internet_archive_movies/index.ttl"
            ],
        [ schema:name "storage-ns"; schema:value "movies" ];
    ui:label "🎬 Movies";
    ui:name "ia-player".
:panel-music
    a ui:Component;
    ui:attribute
        [ schema:name "defer"; schema:value "" ],
        [ schema:name "id"; schema:value "panel-music" ],
            [
                schema:name "source";
                schema:value
                    "./plugins/ia-player/libraries/internet_archive_music/index.ttl"
            ],
        [ schema:name "storage-ns"; schema:value "music" ];
    ui:label "🎵 Music";
    ui:name "ia-player".
:panel-news
    a ui:Component;
    ui:attribute
        [ schema:name "id"; schema:value "panel-news" ],
        [ schema:name "reader"; schema:value "inline" ],
        [ schema:name "source"; schema:value "./plugins/news/feeds.ttl#Feeds" ],
        [ schema:name "view"; schema:value "threePanel" ];
    ui:label "📰 News";
    ui:name "sol-feed".
:panel-podz
    a ui:Component;
    ui:attribute
        [ schema:name "defer"; schema:value "" ],
        [ schema:name "id"; schema:value "panel-podz" ],
        [ schema:name "source"; schema:value "./plugins/podz/dk-podz.html" ];
    ui:label "🗂 Workspaces";
    ui:name "dk-podz".
:panel-solidos
    a ui:Component;
    ui:attribute
        [ schema:name "defer"; schema:value "" ],
        [ schema:name "id"; schema:value "panel-solidos" ],
            [
                schema:name "source";
                schema:value "./plugins/solidos/dk-solidos.html"
            ];
    ui:label "🐧 SolidOS";
    ui:name "dk-solidos".
:RDF-Validator
    a ui:Link;
    ui:href "http://easyrdf.org/converter";
    ui:icon "🧬";
    ui:label "RDF Validator";
    ui:region ui:Tab.
:SHACL-Playground
    a ui:Link;
    ui:href "https://shacl.org/playground/";
    ui:icon "✅";
    ui:label "SHACL Playground";
    ui:region ui:Tab.
