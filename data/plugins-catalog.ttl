@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

# The plugin lists <sol-plugin-manager> manages (Manage Plugins drags entries
# between them; Manage Menus offers #InUse for dragging onto the menu/bar
# managers). Two ui:Menu lists of ui:Component entries over one shared pool,
# seeded by tools/seed-plugins-catalog.mjs and edited by the manager thereafter.
# Each entry's ui:icon is an emoji character (system emoji font — no bundled
# image assets) and its rdfs:comment is the card blurb.

<#InUse> a ui:Menu ; ui:label "Plugins to Use" ;
  rdfs:comment "The plugins this app uses — the palette Manage Menus offers for dragging onto the tab menu and button bar. Edited with Manage Plugins (drag between lists; auto-saves)." ;
  ui:parts ( <#News-three-panel-feeds> <#Music-Internet-Archive> <#Movies-Internet-Archive> <#Images-Wikimedia> <#Workspaces-pod-browser> <#Dev-Tools-playgrounds> <#Search> <#Calendar> <#Sign-in> ) .

<#Available> a ui:Menu ; ui:label "Plugins Available" ;
  rdfs:comment "Plugins on the shelf — known to the app but not in use. Drag a manifest URL (or type it) into Manage Plugins to add one; drag a card to Plugins to Use to adopt it." ;
  ui:parts ( <#SolidOS-data-browser> <#Weather> <#Clock> <#0data-Hello> <#BilliPod> <#Booklice> <#dokieli> <#FilePod> <#GeoPod> <#HealthPod> <#HomeVault> <#InnerPod> <#KeyPod> <#KonaPod> <#Media-Kraken> <#MovieStar> <#MSFatigue> <#NotePod> <#ODI-Solid-File-Manager> <#Penny> <#Pod-Drive> <#Pod-Pro> <#Pod-Resume> <#PodCal> <#PodOS-Browser> <#Portable-LibreChat> <#RoloPod> <#SecureDialog> <#Solid-File-Manager> <#Solidflix> <#SolidFocus> <#SolidOS-Databrowser> <#Synara-AI> <#Tired-Bike> <#TodoPod> <#Umai> <#VitalStats> ) .

# The whole catalog in one list — the ☰ "All Plugins…" page
# (pages/all-plugins.html) browses this.
<#All> a ui:Menu ; ui:label "All Plugins" ;
  rdfs:comment "Every plugin in the catalog, in use or not — what pages/all-plugins.html displays. Seeded; not maintained by Manage Plugins saves." ;
  ui:parts ( <#News-three-panel-feeds> <#Music-Internet-Archive> <#Movies-Internet-Archive> <#Images-Wikimedia> <#Workspaces-pod-browser> <#SolidOS-data-browser> <#Dev-Tools-playgrounds> <#Search> <#Calendar> <#Sign-in> <#Weather> <#Clock> <#0data-Hello> <#BilliPod> <#Booklice> <#dokieli> <#FilePod> <#GeoPod> <#HealthPod> <#HomeVault> <#InnerPod> <#KeyPod> <#KonaPod> <#Media-Kraken> <#MovieStar> <#MSFatigue> <#NotePod> <#ODI-Solid-File-Manager> <#Penny> <#Pod-Drive> <#Pod-Pro> <#Pod-Resume> <#PodCal> <#PodOS-Browser> <#Portable-LibreChat> <#RoloPod> <#SecureDialog> <#Solid-File-Manager> <#Solidflix> <#SolidFocus> <#SolidOS-Databrowser> <#Synara-AI> <#Tired-Bike> <#TodoPod> <#Umai> <#VitalStats> ) .

# Topic categories — skos:Collections over the same pool; the grouped
# plugin manager renders these as headings. A plugin manifest's
# dct:subject names its category; imports file entries here.
<#Information> a skos:Collection ; skos:prefLabel "Information" ;
  skos:member <#News-three-panel-feeds>, <#Search>, <#Calendar>, <#Weather>, <#Clock>, <#GeoPod> .

<#Media> a skos:Collection ; skos:prefLabel "Media" ;
  skos:member <#Music-Internet-Archive>, <#Movies-Internet-Archive>, <#Images-Wikimedia>, <#Media-Kraken>, <#MovieStar>, <#Solidflix> .

<#Tech> a skos:Collection ; skos:prefLabel "Tech" ;
  skos:member <#Workspaces-pod-browser>, <#SolidOS-data-browser>, <#Dev-Tools-playgrounds>, <#Sign-in>, <#0data-Hello> .

<#Productivity> a skos:Collection ; skos:prefLabel "Productivity" ;
  skos:member <#BilliPod>, <#Booklice>, <#HomeVault>, <#KeyPod>, <#KonaPod>, <#Pod-Resume>, <#PodCal>, <#SolidFocus>, <#Synara-AI>, <#TodoPod> .

<#Content-Notes-Blogging-and-Publishing> a skos:Collection ; skos:prefLabel "Content, Notes, Blogging and Publishing" ;
  skos:member <#dokieli>, <#NotePod>, <#RoloPod> .

<#Pod-Management> a skos:Collection ; skos:prefLabel "Pod Management" ;
  skos:member <#FilePod>, <#ODI-Solid-File-Manager>, <#Penny>, <#Pod-Drive>, <#Pod-Pro>, <#PodOS-Browser>, <#Solid-File-Manager>, <#SolidOS-Databrowser> .

<#Health> a skos:Collection ; skos:prefLabel "Health" ;
  skos:member <#HealthPod>, <#InnerPod>, <#MSFatigue>, <#SecureDialog>, <#VitalStats> .

<#Security> a skos:Collection ; skos:prefLabel "Security" ;
  skos:member <#KeyPod> .

<#Chat> a skos:Collection ; skos:prefLabel "Chat" ;
  skos:member <#Portable-LibreChat> .

<#Community> a skos:Collection ; skos:prefLabel "Community" ;
  skos:member <#Tired-Bike> .

<#Cooking> a skos:Collection ; skos:prefLabel "Cooking" ;
  skos:member <#Umai> .

