  rdfs:comment "Log blood pressure, weight and other vital signs." ;
  ui:href <https://vitalstats.apps.privatedatapod.com/> .

<#News-three-panel-feeds> a ui:Component ; ui:label "News (three-panel feeds)" ; ui:name "sol-feed" ;
  ui:icon "📰" ;
  rdfs:comment "Read news feeds in a three-panel reader: sources, headlines, article." ;
  ui:attribute
    [ schema:name "view" ; schema:value "threePanel" ] ,
    [ schema:name "reader" ; schema:value "inline" ] ,
    [ schema:name "source" ; schema:value "./plugins/news/feeds.ttl#Feeds" ] .

<#Music-Internet-Archive> a ui:Component ; ui:label "Music (Internet Archive)" ; ui:name "ia-player" ;
  ui:icon "🎵" ;
  rdfs:comment "Browse and play music collections from the Internet Archive." ;
  ui:attribute
    [ schema:name "storage-ns" ; schema:value "music" ] ,
    [ schema:name "defer" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./plugins/ia-player/libraries/internet_archive_music/index.ttl" ] .

<#Movies-Internet-Archive> a ui:Component ; ui:label "Movies (Internet Archive)" ; ui:name "ia-player" ;
  ui:icon "🎬" ;
  rdfs:comment "Browse and play films from the Internet Archive." ;
  ui:attribute
    [ schema:name "storage-ns" ; schema:value "movies" ] ,
    [ schema:name "favourites-only" ; schema:value "" ] ,
    [ schema:name "defer" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./plugins/ia-player/libraries/internet_archive_movies/index.ttl" ] .

<#Images-Wikimedia> a ui:Component ; ui:label "Images (Wikimedia)" ; ui:name "omp-images" ;
  ui:icon "🖼" ;
  rdfs:comment "Browse Wikimedia image galleries." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/omp-images/libraries/wikimedia_images/images.ttl#Images" ] .

<#Workspaces-pod-browser> a ui:Component ; ui:label "Workspaces (pod browser)" ; ui:name "dk-podz" ;
  ui:icon "🗂" ;
  rdfs:comment "Browse and manage your Solid pods and workspaces." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/podz/dk-podz.html" ] ,
    [ schema:name "defer" ; schema:value "" ] .

<#SolidOS-data-browser> a ui:Component ; ui:label "SolidOS (data browser)" ; ui:name "dk-solidos" ;
  ui:icon "🐧" ;
  rdfs:comment "The SolidOS data browser, embedded." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/solidos/dk-solidos.html" ] ,
    [ schema:name "defer" ; schema:value "" ] .

<#Dev-Tools-playgrounds> a ui:Component ; ui:label "Dev Tools (playgrounds)" ; ui:name "sol-include" ;
  ui:icon "🛠" ;
  rdfs:comment "JSON-LD, RDF, SHACL and SPARQL playgrounds, plus Solid resources." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/dev-tools/dev-tools.html" ] ,
    [ schema:name "trusted" ; schema:value "" ] .

<#Search> a ui:Component ; ui:label "Search" ; ui:name "sol-search" ;
  ui:icon "🔍" ;
  rdfs:comment "Search box for the button bar (pluggable search engines)." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/search/search-engines.ttl#SearchEngines" ] .

<#Calendar> a ui:Component ; ui:label "Calendar" ; ui:name "dk-calendar-popout" ;
  ui:icon "📅" ;
  rdfs:comment "Pop-out month calendar for the button bar." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/calendar/calendar-settings.ttl#All" ] .

<#Sign-in> a ui:Component ; ui:label "Sign in" ; ui:name "sol-login" ;
  ui:icon "🔑" ;
  rdfs:comment "Solid sign-in button (popup flow)." ;
  ui:attribute
    [ schema:name "mode" ; schema:value "popup" ] ,
    [ schema:name "popup-callback" ; schema:value "node_modules/podz/popup-auth-callback.html" ] ,
    [ schema:name "issuers" ; schema:value "https://solidcommunity.net,https://solidweb.me,https://solidweb.org,https://login.inrupt.com" ] .

<#Weather> a ui:Component ; ui:label "Weather" ; ui:name "sol-weather" ;
  ui:icon "🌤" ;
  rdfs:comment "Weather widget (location and units in its settings file)." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/weather/weather-settings.ttl#Settings" ] .

<#Clock> a ui:Component ; ui:label "Clock" ; ui:name "sol-time" ;
  ui:icon "🕐" ;
  rdfs:comment "Clock widget (timezone in its settings file)." ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/time/time-settings.ttl#Settings" ] .

