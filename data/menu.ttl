@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .
@prefix acl:    <http://www.w3.org/ns/auth/acl#> .

# ── The ☰ hamburger menu (chrome) ────────────────────────────────────────
# Consumed by <sol-dropdown-button source="./data/menu.ttl#More" region="modal">
# in html-first.html: component items display in the #dk-menu-pane replace
# pane over the tab content (it claims them by id via data-for in index.html;
# unclaimed items would fall back to the region= modal); bare-name items
# dispatch sol-command (resolved by the dk-tabs-shell registry); acl:Write
# items are hidden for guests (body.no-write ::part(requires-write)).
# (The RETIRED old-dk #MainMenu block that used to sit above was removed
# 2026-06-12 — see git history if it's ever wanted back.)

<#More> a ui:Menu ; ui:label "Menu" ;
  ui:parts ( <#MorePlugins> <#MoreCustomize> <#MoreSettings> <#MoreTheme> <#MoreFontSize>
             <#MoreSignIn> <#MoreGuestView> <#MoreReload> <#MoreRestart> ) .

# Manage Plugins edits the two plugin lists (data/plugins-catalog.ttl#InUse /
# #Available); its Plugins-to-Use list is what Manage Menus offers.
<#MorePlugins> a ui:Component ; ui:label "Manage Plugins…" ;
  ui:name "sol-include" ;
  acl:mode acl:Write ;
  ui:attribute
    [ schema:name "source"  ; schema:value "./plugins/manage-plugins/dk-manage-plugins.html" ] ,
    [ schema:name "trusted" ; schema:value "" ] .

<#MoreCustomize> a ui:Component ; ui:label "Manage Menus…" ;
  ui:name "sol-include" ;
  acl:mode acl:Write ;
  ui:attribute
    [ schema:name "source"  ; schema:value "./plugins/customize/dk-customize.html" ] ,
    [ schema:name "trusted" ; schema:value "" ] .

# Settings is a COMMAND: the shell resolves it per context — the active
# plugin's shape (manifest dct:conformsTo) opens a sol-form for the panel's
# source; otherwise the global pages/settings.html. See dk-tabs-shell.
<#MoreSettings> a ui:Component ; ui:label "Settings…" ; ui:name "settings" .

# Label shows the CURRENT theme/size — dk-tabs-shell rewrites these two on open.
<#MoreTheme> a ui:Component ; ui:label "Theme" ; ui:name "toggleTheme" .

<#MoreSignIn> a ui:Component ; ui:label "Sign in…" ; ui:name "signIn" .

<#MoreGuestView> a ui:Component ; ui:label "View as guest" ; ui:name "guestView" ;
  acl:mode acl:Write .

# Cycle text size (moved here from the actions bar). Command — see dk-tabs-shell.
<#MoreFontSize> a ui:Component ; ui:label "Text size" ; ui:name "cycleFontSize" .

# Developer reloads (commands — see dk-tabs-shell). Reload = renderer reload
# (picks up bundle/html/css/data); Restart = relaunch the whole app (also
# main process + bundled servers) via the dkElectron preload bridge.
<#MoreReload>  a ui:Component ; ui:label "Reload dk"  ; ui:name "reloadApp"  .
<#MoreRestart> a ui:Component ; ui:label "Restart dk" ; ui:name "restartApp" .




