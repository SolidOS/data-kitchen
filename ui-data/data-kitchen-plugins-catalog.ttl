:Calendar
    a ui:Plugin;
    dct:conformsTo sha:calendar-settings.shacl;
    dct:publisher "Jeff Zucker";
    dct:references dat:calendar-settings.ttl;
    dct:source plug:calendar.ttl;
    schema:additionalType ui:Component;
    schema:description "Pop-out month calendar for the button bar.";
    schema:url we:sol-button.js;
    ui:attribute
        [ schema:name "class"; schema:value "omp-calendar" ],
        [ schema:name "data-handler"; schema:value "sol-calendar" ],
        [ schema:name "hide-header"; schema:value "" ],
        [ schema:name "label"; schema:value "📅" ],
        [ schema:name "region"; schema:value "dropdown" ],
            [
                schema:name "source";
                schema:value
                "./dk-pod/dk/plugins/calendar/calendar-settings.ttl#All"
            ],
        [ schema:name "title"; schema:value "Calendar" ];
    ui:icon "📅";
    ui:label "Calendar".
:Clock
    a ui:Plugin;
    dct:conformsTo sha:time-settings.shacl;
    dct:publisher "Jeff Zucker";
    dct:references dat:time-settings.ttl;
    dct:source plug:clock.ttl;
    schema:additionalType ui:Component;
    schema:description "Clock widget (timezone in its settings file).";
    schema:url we:sol-time.js;
    ui:attribute
            [
                schema:name "source";
                schema:value
                "./dk-pod/dk/plugins/time/time-settings.ttl#Settings"
            ];
    ui:icon "🕐";
    ui:label "Clock".
