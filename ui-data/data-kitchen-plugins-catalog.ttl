    dct:conformsTo ia:music.shacl;
    dct:publisher "Jeff Zucker";
    dct:references inte:index.ttl;
    dct:source plug:spoken-word.ttl;
    schema:additionalProperty
        [ schema:name "defer"; schema:value "" ],
        [ schema:name "id"; schema:value "panel-spoken-word" ],
            [
                schema:name "source";
                schema:value
                    "./dk-pod/dk/plugins/ia-player/libraries/internet_archive_spoken_word/index.ttl"
            ],
        [ schema:name "storage-ns"; schema:value "spoken-word" ];
    schema:additionalType ui:Component;
    schema:description
    "Browse and play poetry, audiobooks, and talks from the Internet Archive.";
    schema:softwareHelp ass:ia-help.html;
    schema:url dis:ia-player.esm.js;
    ui:icon "🎙️";
    ui:label "Spoken Word (Internet Archive)".
