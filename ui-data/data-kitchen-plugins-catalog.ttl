    schema:additionalType ui:Link;
    schema:description "File browser for multiple platforms.";
    schema:url <https://filepod.solidcommunity.au>;
    ui:icon "https://filepod.solidcommunity.au/filepod/icons/Icon-192.png";
    ui:label "FilePod".
:GeoPod
    a ui:Plugin;
    dct:publisher "Software Innovation Institute, ANU";
