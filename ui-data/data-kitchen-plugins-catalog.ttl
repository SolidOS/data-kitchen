:0data-Hello
    a ui:Plugin;
    dct:publisher "0data";
    dct:source plug:0data-hello.ttl;
    schema:additionalType ui:Link;
    schema:description "Tiny demo app showing data stored in your pod.";
    schema:url sol:;
    ui:icon "https://hello.0data.app/favicon.ico";
    ui:label "0data Hello".
:Available
    a ui:Menu;
    schema:itemListElement
        :Available-0data-Hello, :Available-BilliPod, :Available-Bluesky,
        :Available-Booklice, :Available-Calendar, :Available-Clock,
        :Available-CryptPad, :Available-Customize,
        :Available-Data-Kitchen-Pod-Browser, :Available-dokieli,
        :Available-Duck-ai, :Available-Element, :Available-FilePod,
        :Available-GeoPod, :Available-Gmail, :Available-Google-Calendar,
        :Available-Google-Maps, :Available-Google-Messages,
        :Available-HealthPod, :Available-HomeVault, :Available-HuggingFace-Chat,
        :Available-Images-Wikimedia, :Available-InnerPod,
        :Available-JSON-LD-Playground, :Available-KeyPod, :Available-KonaPod,
        :Available-Lemmy, :Available-LibreTranslate, :Available-Mastodon,
        :Available-Matrix-Chat, :Available-Media-Kraken,
        :Available-Movies-Internet-Archive, :Available-MovieStar,
        :Available-MSFatigue, :Available-Music-Internet-Archive,
        :Available-News-three-panel-feeds, :Available-NotePod,
        :Available-ODI-Solid-File-Manager, :Available-OpenStreetMap,
        :Available-Penny, :Available-Pixelfed, :Available-Pod-Drive,
        :Available-Pod-Pro, :Available-Pod-Resume, :Available-PodCal,
        :Available-PodOS-Browser, :Available-Portable-LibreChat,
        :Available-Proton-Calendar, :Available-Proton-Drive,
        :Available-Proton-Mail, :Available-RDF-Validator, :Available-Restart-dk,
        :Available-RoloPod, :Available-Search, :Available-SearXNG,
        :Available-SecureDialog, :Available-SepiaSearch, :Available-Settings,
        :Available-SHACL-Playground, :Available-Sign-in,
        :Available-Solid-Catalog, :Available-Solid-FAQ,
        :Available-Solid-File-Manager, :Available-Solid-Forum,
        :Available-Solid-Glossary, :Available-Solid-Website,
        :Available-Solid-World-Videos, :Available-Solidflix,
        :Available-SolidFocus, :Available-SolidOS-AddressBook,
        :Available-SolidOS-Chat, :Available-SolidOS-data-browser,
        :Available-SolidOS-Meeting, :Available-SolidOS-Notes,
        :Available-SolidOS-Tasks, :Available-SPARQL-Playground,
        :Available-Spoken-Word-Internet-Archive, :Available-Standard-Notes,
        :Available-Synara-AI, :Available-Tag-Explainer, :Available-Text-size,
        :Available-Theme, :Available-Tired-Bike, :Available-TodoPod,
        :Available-Tuta, :Available-Umai, :Available-VitalStats,
        :Available-Weather;
    rdfs:comment
        "Every plugin and app the catalog knows, generated from the flat manifests in plugins/. In use means ui-data/data-kitchen-main-menu.ttl mounts it.";
    ui:label "Plugins Available".
