:0data-Hello
    a ui:Plugin;
    dct:publisher "0data";
    dct:source plug:0data-hello.ttl;
    schema:additionalType ui:Link;
    schema:description "Tiny demo app showing data stored in your pod.";
    schema:url sol:;
    ui:icon "https://hello.0data.app/favicon.ico";
    ui:label "0data Hello".
:App-Builder
    a ui:Plugin;
    dct:publisher "Jeff Zucker";
    dct:source plug:app-builder.ttl;
    schema:keywords "UI Controls";
    schema:additionalType ui:Component;
    schema:description
        "Build your own app: pick a layout, add menus and plugins, publish to your pod.";
    schema:url we:sol-include.js;
    ui:attribute
        [ schema:name "if-logged-in"; schema:value "" ],
            [
                schema:name "source";
                schema:value "./dk-pod/dk/pages/app-builder.html"
            ],
        [ schema:name "trusted"; schema:value "" ];
    ui:icon "🏗️";
    ui:label "App Builder".
:Available
    a ui:Menu;
    schema:itemListElement
        :0data-Hello, :App-Builder, :BilliPod, :Bluesky, :Booklice, :Calendar,
        :Clock, :CryptPad, :Customize, :Data-Kitchen-Pod-Browser, :dokieli,
        :Duck-ai, :Element, :FilePod, :GeoPod, :Gmail, :Google-Calendar,
        :Google-Maps, :Google-Messages, :HealthPod, :HomeVault,
        :HuggingFace-Chat, :Images-Wikimedia, :InnerPod, :JSON-LD-Playground,
        :KeyPod, :KonaPod, :Lemmy, :LibreTranslate, :Mastodon, :Matrix-Chat,
        :Media-Kraken, :Movies-Internet-Archive, :MovieStar, :MSFatigue,
        :Music-Internet-Archive, :News-three-panel-feeds, :NotePod,
        :ODI-Solid-File-Manager, :OpenStreetMap, :Penny, :Pixelfed, :Pod-Drive,
        :Pod-Pro, :Pod-Resume, :PodCal, :PodOS-Browser, :Portable-LibreChat,
        :Proton-Calendar, :Proton-Drive, :Proton-Mail, :RDF-Validator,
        :Restart-dk, :RoloPod, :Search, :SearXNG, :SecureDialog, :SepiaSearch,
        :Settings, :SHACL-Playground, :Sign-in, :Solid-Catalog, :Solid-FAQ,
        :Solid-File-Manager, :Solid-Forum, :Solid-Glossary, :Solid-Website,
        :Solidflix, :SolidFocus, :SolidOS-AddressBook, :SolidOS-Chat,
        :SolidOS-data-browser, :SolidOS-Meeting, :SolidOS-Notes, :SolidOS-Tasks,
        :SPARQL-Playground, :Spoken-Word-Internet-Archive, :Standard-Notes,
        :Synara-AI, :Tag-Explainer, :Text-size, :Theme, :Tired-Bike, :TodoPod,
        :Tuta, :Umai, :VitalStats, :Weather;
    rdfs:comment
        "Every plugin and app the catalog knows, generated from the flat manifests in plugins/. In use means ui-data/data-kitchen-main-menu.ttl mounts it.";
    ui:label "Plugins Available".
