    schema:additionalType ui:Link;
    schema:description "Home inventory for insurance and household records.";
    schema:url hom:;
    ui:icon
    "https://homevault.apps.privatedatapod.com/icons/apple-touch-icon.png";
    ui:label "HomeVault".
:HuggingFace-Chat
    a ui:Plugin;
    dct:publisher "Hugging Face";
    dct:source plug:huggingface-chat.ttl;
    schema:additionalType ui:Link;
    schema:description "Chat with open-source AI models.";
    schema:url chat:;
    ui:icon "https://huggingface.co/chat/huggingchat/apple-touch-icon.png";
    ui:label "HuggingFace Chat".
:Images-Wikimedia
    a ui:Plugin;
    dct:publisher "Jeff Zucker";
    dct:source plug:images.ttl;
    schema:additionalProperty
        [ schema:name "id"; schema:value "panel-images" ],
            [
                schema:name "source";
                schema:value
                    "./dk-pod/dk/plugins/omp-images/libraries/wikimedia_images/images.ttl#Images"
            ];
    schema:additionalType ui:Component;
    schema:description "Browse Wikimedia image galleries.";
    schema:url dis:omp-images.esm.js;
    ui:icon "🖼";
    ui:label "Images (Wikimedia)".
:Information
    a skos:Collection;
    skos:member
        :Calendar, :Clock, :GeoPod, :News-three-panel-feeds, :Search, :Umai,
        :Weather;
    skos:prefLabel "Information".
:InnerPod
    a ui:Plugin;
    dct:publisher "Software Innovation Institute, ANU";
    dct:source plug:innerpod.ttl;
    schema:additionalType ui:Link;
    schema:description "Guided meditation timer that records your sessions.";
