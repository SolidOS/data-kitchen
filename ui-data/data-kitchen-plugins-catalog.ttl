:BilliPod
    a ui:Plugin;
    dct:publisher "Togaware";
    dct:source plug:billipod.ttl;
    schema:additionalType ui:Link;
    schema:description "Track bills with payment reminders.";
    schema:url <https://billipod.solidcommunity.au>;
    ui:icon "https://billipod.solidcommunity.au/billipod/icons/Icon-192.png";
    ui:label "BilliPod".
:Bluesky
    a ui:Plugin;
    dct:publisher "Bluesky";
    dct:source plug:bluesky.ttl;
    schema:additionalType ui:Link;
    schema:description "Distributed social network (AT Protocol).";
    schema:url bsky:;
    ui:icon "https://web-cdn.bsky.app/static/apple-touch-icon.png";
    ui:label "Bluesky".
:Booklice
    a ui:Plugin;
    dct:publisher "scenaristeur";
    dct:source plug:booklice.ttl;
    schema:additionalType ui:Link;
    schema:description "Bookmarks you can share with a community.";
    schema:url boo:;
    ui:icon
        "https://scenaristeur.github.io/booklice/img/icons/apple-touch-icon-152x152.png";
    ui:label "Booklice".
:Calendar
    a ui:Plugin;
    dct:conformsTo sha:calendar-settings.shacl;
    dct:publisher "Jeff Zucker";
    dct:references dat:calendar-settings.ttl;
    dct:source plug:calendar.ttl;
    schema:additionalProperty
        [ schema:name "class"; schema:value "omp-calendar" ],
        [ schema:name "data-handler"; schema:value "sol-calendar" ],
        [ schema:name "hide-header"; schema:value "" ],
        [ schema:name "label"; schema:value "📅" ],
            [
                schema:name "source";
                schema:value
                "./dk-pod/dk/plugins/calendar/calendar-settings.ttl#All"
            ],
        [ schema:name "title"; schema:value "Calendar" ];
    schema:additionalType ui:Component;
    schema:description "Pop-out month calendar for the button bar.";
    schema:url we:sol-button.js;
    ui:icon "📅";
    ui:label "Calendar";
    ui:region ui:Dropdown.
:Clock
    a ui:Plugin;
    dct:conformsTo sha:time-settings.shacl;
    dct:publisher "Jeff Zucker";
    dct:references dat:time-settings.ttl;
    dct:source plug:clock.ttl;
    schema:additionalProperty
            [
                schema:name "source";
                schema:value
                "./dk-pod/dk/plugins/time/time-settings.ttl#Settings"
            ];
    schema:additionalType ui:Component;
    schema:description "Clock widget (timezone in its settings file).";
    schema:url we:sol-time.js;
    ui:icon "🕐";
    ui:label "Clock".
:Community
    a skos:Collection;
    skos:member :Booklice, :Solid-Forum, :Tired-Bike;
    skos:prefLabel "Community".
:Content-Publishing
    a skos:Collection;
    skos:member :dokieli, :NotePod;
    skos:prefLabel "Content Publishing".
:CryptPad
    a ui:Plugin;
    dct:publisher "CryptPad";
    dct:source plug:cryptpad.ttl;
    schema:additionalType ui:Link;
    schema:description "Encrypted collaborative documents.";
    schema:url cry:;
    ui:icon "https://cryptpad.fr/customize/favicon/main-favicon.png";
    ui:label "CryptPad".
:Customize
    a ui:Plugin;
    schema:additionalProperty
        [ schema:name "if-logged-in"; schema:value "" ],
            [
                schema:name "source";
                schema:value "./dk-pod/dk/pages/customize.html"
            ],
        [ schema:name "trusted"; schema:value "" ];
    schema:additionalType ui:Component;
    schema:description "Choose plugins for your menus and bar.";
    schema:keywords "UI Controls";
    schema:url we:sol-include.js;
    ui:label "Customize".
:Data-Kitchen-Pod-Browser
    a ui:Plugin;
    dct:conformsTo sha:pod-settings.shacl;
    dct:publisher "Jeff Zucker";
    dct:references po:pod-settings.ttl;
    dct:source plug:workspaces.ttl;
    schema:additionalProperty
        [ schema:name "defer"; schema:value "" ],
        [ schema:name "id"; schema:value "panel-podz" ],
            [
                schema:name "source";
                schema:value "./dk-pod/dk/plugins/podz/dk-podz.html"
            ];
    schema:additionalType ui:Component;
    schema:description "Browse and manage your Solid pods and workspaces.";
    schema:softwareHelp po:help.html;
    schema:url po:dk-podz.js;
    ui:icon "/assets/dk-logo.png";
    ui:label "Data Kitchen Pod Browser".
:dokieli
    a ui:Plugin;
    dct:publisher "Sarven Capadisli and Virginia Balseiro";
    dct:source plug:dokieli.ttl;
    schema:additionalProperty [ schema:name "defer"; schema:value "" ];
    schema:additionalType ui:Component;
    schema:description
    "Write and publish articles, with annotations and social interactions.";
    schema:url sol2:dk-dokieli.js;
    ui:icon "https://dokie.li/media/images/logo.png";
    ui:label "dokieli".
:Duck-ai
    a ui:Plugin;
    dct:publisher "DuckDuckGo";
    dct:source plug:duck-ai.ttl;
    schema:additionalType ui:Link;
    schema:description "Private AI chat from DuckDuckGo.";
    schema:url <https://duck.ai>;
    ui:icon "https://duck.ai/apple-touch-icon.png";
    ui:label "Duck.ai".
:Element
    a ui:Plugin;
    dct:publisher "Element";
    dct:source plug:element.ttl;
    schema:additionalType ui:Link;
    schema:description "Matrix client for secure, decentralized chat.";
    schema:url app:;
    ui:icon "https://app.element.io/vector-icons/180.30b915f.png";
    ui:label "Element".
:FilePod
    a ui:Plugin;
    dct:publisher "Software Innovation Institute, ANU";
