@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .
@prefix :       <#> .

# Plugin settings groups rendered on the Settings page by <dk-plugin-settings>.
# One entry per plugin that HAS settings. Each group is shown ONLY while its
# ui:name plugin is "in use" — i.e. wired into the active shell
# (data-kitchen-main-menu.ttl) — not when it is merely parked in the catalog.
#
# Reuses the same vocab the catalog/menu already use (ui:name, ui:label,
# ui:attribute + schema:name/schema:value) — no new terms. `shape` is the SHACL
# shape and `subject` the settings doc#fragment the form edits.

<#PodBrowser> a ui:Component ;
  ui:name  "dk-podz" ;
  ui:label "Data Kitchen Pod Browser" ;
  ui:attribute
    [ schema:name "shape" ;   schema:value "node_modules/sol-components/shapes/pod-settings.shacl" ] ,
    [ schema:name "subject" ; schema:value "./dk-pod/dk/plugins/sol-pod/pod-settings.ttl#Settings" ] .
