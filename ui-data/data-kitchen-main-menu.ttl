@prefix : <#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix schema: <http://schema.org/>.
@prefix ui: <http://www.w3.org/ns/ui#>.
@prefix data: <data-kitchen-plugins-catalog.ttl#>.
@prefix web: </node_modules/sol-components/web/>.
@prefix plu: <../plugins/>.

:Apps
    a ui:Menu;
    schema:itemListElement
        :Apps-dokieli, :Apps-GeoPod, :Apps-KonaPod, :Apps-NotePod, :Apps-PodCal,
        :Apps-RoloPod, :Apps-SolidFocus, :Apps-SolidOS-AddressBook,
        :Apps-SolidOS-Chat, :Apps-SolidOS-Meeting, :Apps-SolidOS-Notes,
        :Apps-SolidOS-Tasks, :Apps-Umai;
    ui:label "Apps".
:Apps-dokieli a schema:ListItem; schema:item data:dokieli; schema:position 1 .

:Apps-GeoPod a schema:ListItem; schema:item data:GeoPod; schema:position 6 .

:Apps-KonaPod a schema:ListItem; schema:item data:KonaPod; schema:position 4 .

:Apps-NotePod a schema:ListItem; schema:item data:NotePod; schema:position 8 .

:Apps-PodCal a schema:ListItem; schema:item data:PodCal; schema:position 7 .

:Apps-RoloPod a schema:ListItem; schema:item data:RoloPod; schema:position 3 .

:Apps-SolidFocus
a schema:ListItem; schema:item data:SolidFocus; schema:position 2 .
:Apps-SolidOS-AddressBook
a schema:ListItem; schema:item data:SolidOS-AddressBook; schema:position 11 .
:Apps-SolidOS-Chat
a schema:ListItem; schema:item data:SolidOS-Chat; schema:position 10 .
:Apps-SolidOS-Meeting
a schema:ListItem; schema:item data:SolidOS-Meeting; schema:position 9 .
:Apps-SolidOS-Notes
a schema:ListItem; schema:item data:SolidOS-Notes; schema:position 13 .
:Apps-SolidOS-Tasks
a schema:ListItem; schema:item data:SolidOS-Tasks; schema:position 12 .
:Apps-Umai a schema:ListItem; schema:item data:Umai; schema:position 5 .

:Bar
    a ui:Menu;
    schema:itemListElement
        :Bar-Bluesky, :Bar-Calendar, :Bar-Duck-ai, :Bar-Mastodon,
        :Bar-Matrix-Chat, :Bar-OpenStreetMap, :Bar-Search;
    ui:label "Top Row Buttons";
    ui:orientation ui:Horizontal.
:Bar-Bluesky a schema:ListItem; schema:item data:Bluesky; schema:position 3 .

:Bar-Calendar a schema:ListItem; schema:item data:Calendar; schema:position 7 .

:Bar-Duck-ai a schema:ListItem; schema:item data:Duck-ai; schema:position 5 .

:Bar-Mastodon a schema:ListItem; schema:item data:Mastodon; schema:position 2 .

:Bar-Matrix-Chat
a schema:ListItem; schema:item data:Matrix-Chat; schema:position 1 .
:Bar-OpenStreetMap
a schema:ListItem; schema:item data:OpenStreetMap; schema:position 4 .
:Bar-Search a schema:ListItem; schema:item data:Search; schema:position 6 .

:Chrome
    a ui:Menu;
    schema:itemListElement :Chrome-chrome-help, :Chrome-chrome-menu;
    ui:label "chrome".
:Chrome-chrome-help
a schema:ListItem; schema:item :chrome-help; schema:position 1 .
:Chrome-chrome-menu
a schema:ListItem; schema:item :chrome-menu; schema:position 2 .
:chrome-help
    a ui:Component;
    schema:additionalProperty
        [ schema:name "aria-label"; schema:value "Help" ],
        [ schema:name "class"; schema:value "omp-help-launch" ],
        [ schema:name "data-handler"; schema:value "sol-include" ],
            [
                schema:name "if-logged-in";
                schema:value "./dk-pod/dk/help/dk-owner.html"
            ],
        [ schema:name "inline"; schema:value "" ],
        [ schema:name "source"; schema:value "./dk-pod/dk/help/dk.html" ],
        [ schema:name "title"; schema:value "Help" ],
        [ schema:name "trusted"; schema:value "" ];
    schema:url web:sol-button.js;
    rdfs:comment
        "Help — opens ./help/dk.html (or ./help/dk-owner.html when signed in) in a trusted inline overlay.";
    ui:label "?".
:chrome-menu
    a ui:Component;
    schema:additionalProperty
        [ schema:name "aria-label"; schema:value "Menu" ],
        [ schema:name "class"; schema:value "omp-more" ],
        [ schema:name "data-settings-skip"; schema:value "" ],
        [ schema:name "label"; schema:value "☰" ],
        [ schema:name "region"; schema:value "modal" ],
            [
                schema:name "source";
                schema:value
                "./dk-pod/dk/ui-data/data-kitchen-hamburger-menu.ttl#More"
            ],
        [ schema:name "title"; schema:value "Menu" ];
    schema:url web:sol-dropdown-button.js;
    rdfs:comment
        "☰ menu — items live in ui-data/data-kitchen-hamburger-menu.ttl#More (Customize, Settings, Sign in, and owner commands). Component items open in a modal.";
    ui:label "Menu".
:Health
    a ui:Menu;
    schema:itemListElement
        :Health-HealthPod, :Health-InnerPod, :Health-MSFatigue,
        :Health-SecureDialog, :Health-VitalStats;
    ui:label "Health".
:Health-HealthPod
a schema:ListItem; schema:item data:HealthPod; schema:position 1 .
:Health-InnerPod a schema:ListItem; schema:item data:InnerPod; schema:position 2 .

:Health-MSFatigue
a schema:ListItem; schema:item data:MSFatigue; schema:position 3 .
:Health-SecureDialog
a schema:ListItem; schema:item data:SecureDialog; schema:position 5 .
:Health-VitalStats
a schema:ListItem; schema:item data:VitalStats; schema:position 4 .
:item
    a ui:Menu;
    schema:itemListElement
        :item-item-7, :item-Solid-Catalog, :item-Solid-FAQ, :item-Solid-Forum,
        :item-Solid-Glossary, :item-Solid-Website, :item-Tag-Explainer;
    ui:label "About Solid".
:item-item-7
a schema:ListItem; schema:item plu:solid-world-videos.ttl; schema:position 7 .
:item-Solid-Catalog
a schema:ListItem; schema:item data:Solid-Catalog; schema:position 5 .
:item-Solid-FAQ a schema:ListItem; schema:item data:Solid-FAQ; schema:position 1 .

:item-Solid-Forum
a schema:ListItem; schema:item data:Solid-Forum; schema:position 2 .
:item-Solid-Glossary
a schema:ListItem; schema:item data:Solid-Glossary; schema:position 6 .
:item-Solid-Website
a schema:ListItem; schema:item data:Solid-Website; schema:position 3 .
:item-Tag-Explainer
a schema:ListItem; schema:item data:Tag-Explainer; schema:position 4 .
:Media-3
    a ui:Menu;
    schema:itemListElement
        :Media-3-Images-Wikimedia, :Media-3-Media-Kraken,
        :Media-3-Movies-Internet-Archive, :Media-3-MovieStar,
        :Media-3-Music-Internet-Archive, :Media-3-News-three-panel-feeds,
        :Media-3-Solidflix, :Media-3-Spoken-Word-Internet-Archive;
    ui:label "Media".
:Media-3-Images-Wikimedia
a schema:ListItem; schema:item data:Images-Wikimedia; schema:position 4 .
:Media-3-Media-Kraken
a schema:ListItem; schema:item data:Media-Kraken; schema:position 6 .
:Media-3-Movies-Internet-Archive
a schema:ListItem; schema:item data:Movies-Internet-Archive; schema:position 3 .
:Media-3-MovieStar
a schema:ListItem; schema:item data:MovieStar; schema:position 8 .
:Media-3-Music-Internet-Archive
a schema:ListItem; schema:item data:Music-Internet-Archive; schema:position 2 .
:Media-3-News-three-panel-feeds
a schema:ListItem; schema:item data:News-three-panel-feeds; schema:position 1 .
:Media-3-Solidflix
a schema:ListItem; schema:item data:Solidflix; schema:position 7 .
:Media-3-Spoken-Word-Internet-Archive
    a schema:ListItem;
    schema:item data:Spoken-Word-Internet-Archive;
    schema:position 5 .
:panel-dev-tools
    a ui:Menu;
    schema:itemListElement
        :panel-dev-tools-JSON-LD-Playground, :panel-dev-tools-RDF-Validator,
        :panel-dev-tools-SHACL-Playground, :panel-dev-tools-SPARQL-Playground,
        :panel-dev-tools-Synara-AI;
    ui:label "Dev Tools".
:panel-dev-tools-JSON-LD-Playground
a schema:ListItem; schema:item data:JSON-LD-Playground; schema:position 3 .
:panel-dev-tools-RDF-Validator
a schema:ListItem; schema:item data:RDF-Validator; schema:position 1 .
:panel-dev-tools-SHACL-Playground
a schema:ListItem; schema:item data:SHACL-Playground; schema:position 2 .
:panel-dev-tools-SPARQL-Playground
a schema:ListItem; schema:item data:SPARQL-Playground; schema:position 4 .
:panel-dev-tools-Synara-AI
a schema:ListItem; schema:item data:Synara-AI; schema:position 5 .
:Pods-2
    a ui:Menu;
    schema:itemListElement
        :Pods-2-Data-Kitchen-Pod-Browser, :Pods-2-Penny, :Pods-2-PodOS-Browser,
        :Pods-2-SolidOS-data-browser;
    ui:label "Pods".
:Pods-2-Data-Kitchen-Pod-Browser
a schema:ListItem; schema:item data:Data-Kitchen-Pod-Browser; schema:position 1 .
:Pods-2-Penny a schema:ListItem; schema:item data:Penny; schema:position 4 .

:Pods-2-PodOS-Browser
a schema:ListItem; schema:item data:PodOS-Browser; schema:position 3 .
:Pods-2-SolidOS-data-browser
a schema:ListItem; schema:item data:SolidOS-data-browser; schema:position 2 .
:Tabs
    a ui:Menu;
    schema:itemListElement
        :Tabs-Apps, :Tabs-Health, :Tabs-item, :Tabs-Media-3,
        :Tabs-panel-dev-tools, :Tabs-Pods-2;
    ui:label "Menu Tabs";
    ui:orientation ui:Horizontal.
:Tabs-Apps a schema:ListItem; schema:item :Apps; schema:position 4 .

:Tabs-Health a schema:ListItem; schema:item :Health; schema:position 3 .

:Tabs-item a schema:ListItem; schema:item :item; schema:position 5 .

:Tabs-Media-3 a schema:ListItem; schema:item :Media-3; schema:position 2 .

:Tabs-panel-dev-tools
a schema:ListItem; schema:item :panel-dev-tools; schema:position 6 .
:Tabs-Pods-2 a schema:ListItem; schema:item :Pods-2; schema:position 1 .

