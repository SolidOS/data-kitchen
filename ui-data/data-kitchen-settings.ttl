@prefix : <#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix ui: <http://www.w3.org/ns/ui#>.
@prefix ent: <http://www.wikidata.org/entity/>.
@prefix schema: <http://schema.org/>.

<> a ent:Q1193846; foaf:primaryTopic :Settings.

:Settings
    ui:colorScheme ui:SystemColorScheme;
    ui:fontSize ui:MediumFont;
    ui:proxy "http://localhost:8001/proxy?uri=".

# Sign-in issuers: the ordered Solid OIDC issuer list offered by every
# <sol-login> in the app (position 1 = the default). Edited on the Settings
# page via the oidc-issuers.shacl rolodex; applied to the login buttons by
# src/dk-issuers-feed.js. Same positioned-list model as :Locations below.
:Issuers a schema:ItemList;
    schema:name "Sign-in issuers";
    schema:itemListOrder schema:ItemListOrderAscending;
    schema:itemListElement :iss1, :iss2, :iss3, :iss4.

:iss1 a schema:ListItem;
    schema:item <https://solidcommunity.net>;
    schema:name "solidcommunity.net";
    schema:position 1.

:iss2 a schema:ListItem;
    schema:item <https://solidweb.me>;
    schema:name "solidweb.me";
    schema:position 2.

:iss3 a schema:ListItem;
    schema:item <https://solidweb.org>;
    schema:name "solidweb.org";
    schema:position 3.

:iss4 a schema:ListItem;
    schema:item <https://login.inrupt.com>;
    schema:name "login.inrupt.com";
    schema:position 4.

# Pod locations: the ordered storage list feeding every pod selector (podz
# Pod Browser, SolidOS Locations dropdown). Edited on the Settings page via
# the pod-locations.shacl rolodex; synced into the runtime pod registry by
# src/dk-locations-feed.js, which also appends runtime-discovered pods here.
# schema:item URLs are RELATIVE so they resolve against the live origin
# (<../../> = /dk-pod/, <../../../> = the server root /).
:Locations a schema:ItemList;
    schema:name "Pod locations";
    schema:itemListOrder schema:ItemListOrderAscending;
    schema:itemListElement :loc1, :loc2.

:loc1 a schema:ListItem;
    schema:item <../../>;
    schema:name "Data Kitchen Pod";
    schema:position 1.

:loc2 a schema:ListItem;
    schema:item <../../../>;
    schema:name "Local Root";
    schema:position 2.
