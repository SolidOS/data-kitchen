node_modules/
dist/
# electron-builder output (kept separate from dist/ so builds don't swallow
# their own previous artifacts via the files "dist/**" pattern)
release/
*.log
.DS_Store

# rdf2html's editable shell snapshot (scratch; the RDF is the source)
tools/conversion/shell.html

# the pivot server's PRE-COMPILED config is a required, committed artifact
# (regenerating needs an isolated build — see pivot/build-compiled-config.sh)
!pivot/dist/
!pivot/dist/create-app.cjs

# Community Solid Server runtime storage state (POD_ROOT = repo root)
.internal/

# The seeded personal pod instance (POD_ROOT = repo root in dev). The SOURCE is
# the committed pod-template/; dk-pod/ is the per-machine seeded copy.
/dk-pod/
# Root owner announcement, seeded with the live origin (solid:owner → dk-pod WebID)
/.meta

# editor backups / autosave
*~
\#*\#
.\#*

# machine-local Claude Code settings (permission grants, etc.)
.claude/settings.local.json
.claude/launch.json

# Personal notes + Claude session artifacts — not for the public repo
notes.md
claude/
drafts/
# Claude's notes on working with Jeff (personal; skills.md IS committed)
jeff-skills.md
