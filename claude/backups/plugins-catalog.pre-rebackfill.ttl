@prefix : <#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix schema: <http://schema.org/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix ui: <http://www.w3.org/ns/ui#>.

:0data-Hello
    a ui:Link;
    dct:publisher "0data";
    rdfs:comment "Tiny demo app showing data stored in your pod.";
    ui:href "https://hello.0data.app/solid/";
    ui:icon "🧪";
    ui:label "0data Hello";
    ui:region ui:Tab.
:Available
    a ui:Menu;
    rdfs:comment
        "Every plugin and app the catalog knows, generated from the flat manifests in plugins/. In use means data/data-kitchen-main-menu.ttl mounts it.";
    ui:label "Plugins Available";
    ui:parts
            ( :0data-Hello :BilliPod :Bluesky :Booklice :Calendar :Clock
            :CryptPad :dokieli :Duck-ai :Element :GeoPod :HealthPod :HomeVault
            :HuggingFace-Chat :Images-Wikimedia :InnerPod :JSON-LD-Playground
            :KonaPod :Lemmy :LibreTranslate :Mastodon :Matrix-Chat
            :Media-Kraken :Movies-Internet-Archive :MSFatigue
            :Music-Internet-Archive :News-three-panel-feeds
            :ODI-Solid-File-Manager :OpenStreetMap :Penny :Pixelfed :Pod-Drive
            :Pod-Pro :Pod-Resume :PodCal :PodOS-Browser :Portable-LibreChat
            :Proton-Calendar :Proton-Drive :Proton-Mail :RDF-Validator :RoloPod
            :Search :SearXNG :SecureDialog :SepiaSearch :SHACL-Playground
            :Sign-in :Solid-Catalog :Solid-FAQ :Solid-File-Manager
            :Solid-Glossary :Solid-Website :Solidflix :SolidFocus
            :SolidOS-data-browser :SPARQL-Playground :Standard-Notes :Synara-AI
            :Tag-Explainer :Tired-Bike :TodoPod :Tuta :Umai :VitalStats
            :Weather :Workspaces-pod-browser ).
