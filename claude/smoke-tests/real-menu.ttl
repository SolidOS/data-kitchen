@prefix : <#>.
@prefix acl: <http://www.w3.org/ns/auth/acl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix schema: <http://schema.org/>.
@prefix ui: <http://www.w3.org/ns/ui#>.

:Apps a ui:Menu; ui:label "Apps"; ui:parts ( ).

:Bar
    a ui:Menu;
    ui:label "actions";
    ui:orientation ui:Horizontal;
    ui:parts
            ( :Matrix-Chat-2 :Mastodon-2 :Lemmy :SepiaSearch :Pixelfed
            :Bluesky-2 :Duck-ai-3 :bar-search :bar-calendar ).
:bar-calendar
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-calendar" ],
            [
                schema:name "source";
                schema:value
                "./dk-pod/dk/plugins/calendar/calendar-settings.ttl#All"
            ],
        [ schema:name "title"; schema:value "Calendar" ];
    ui:label "Calendar";
    ui:name "dk-calendar-popout".
:bar-fontsize
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-fontsize" ],
        [ schema:name "data-handler"; schema:value "cycleFontSize" ],
        [ schema:name "title"; schema:value "Text size" ];
    ui:label "A";
    ui:name "sol-button".
:bar-login
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-sollogin" ],
            [
                schema:name "issuers";
                schema:value
                    "https://solidcommunity.net,https://solidweb.me,https://solidweb.org,https://login.inrupt.com"
            ],
        [ schema:name "mode"; schema:value "popup" ],
            [
                schema:name "popup-callback";
                schema:value "dk-pod/dk/plugins/podz/popup-auth-callback.html"
            ];
    ui:label "Sign in";
    ui:name "sol-login".
:bar-search
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-search" ],
            [
                schema:name "source";
                schema:value
                "./dk-pod/dk/plugins/search/search-engines.ttl#SearchEngines"
            ],
        [ schema:name "title"; schema:value "Search" ];
    ui:label "Search";
    ui:name "sol-search".
:bar-settings
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-settings-launch" ],
        [ schema:name "data-handler"; schema:value "sol-include" ],
        [ schema:name "inline"; schema:value "" ],
            [
                schema:name "source";
                schema:value "./dk-pod/dk/pages/settings.html"
            ],
        [ schema:name "title"; schema:value "Settings" ],
        [ schema:name "trusted"; schema:value "" ];
    ui:label "⚙";
    ui:name "sol-button".
:bar-theme
    a ui:Component;
    ui:attribute
        [ schema:name "class"; schema:value "omp-theme" ],
        [ schema:name "data-handler"; schema:value "toggleTheme" ],
        [ schema:name "title"; schema:value "Toggle light / dark" ];
    ui:label "🌙";
    ui:name "sol-button".
