@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix solid: <http://www.w3.org/ns/solid/terms#>.
@prefix space: <http://www.w3.org/ns/pim/space#>.
@prefix ldp: <http://www.w3.org/ns/ldp#>.
<>
    a foaf:PersonalProfileDocument;
    foaf:maker <http://localhost:3000/data-kitchen-user/profile/card#me>;
    foaf:primaryTopic <http://localhost:3000/data-kitchen-user/profile/card#me>.

<http://localhost:3000/data-kitchen-user/profile/card#me>
    space:storage <../>;
    ldp:inbox <../inbox/>;
    space:preferencesFile <../settings/prefs.ttl>;
    solid:privateTypeIndex <../settings/privateTypeIndex.ttl>;
    solid:publicTypeIndex <../settings/publicTypeIndex.ttl>;
    solid:oidcIssuer <http://localhost:3000/>;
    a foaf:Person.
