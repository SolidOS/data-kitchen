flowchart TB
      subgraph EL[" "]
         ELHDR{{"ELECTRON<br/>injects x-dk-token"}}
       end

      UNB["Unblessd local page<br/>(no token)"]
      EXT["external app<br/>(off-machine / remote)"]

      subgraph SRV[" "]
        RT["ROUTER :8000<br>rejects if no token"]
        PX["PROXY :8001<br>rejects if no token"]
        subgraph CSSPROC[" "]
          WRAP{{"ELECTRON patches listen</br>rejects if no token"}}
          CSSH["No-auth CSS/PIVOT POD :8010<br>only sees requests with tokens"]
          WRAP -->|pass| CSSH
        end
        RT -->|"forwards x-dk-token"| WRAP
      end

      ELHDR -->|"x-dk-token"| RT
      ELHDR -->|"x-dk-token"| PX
      UNB -.->RT
      UNB -.->PX
      UNB -.->WRAP
      EXT -.->|"no route — bound to 127.0.0.1"| SRV

      classDef src fill:#d6f5d6,stroke:#00aa00,stroke-width:2px,color:#006600;
      classDef bad fill:#ffdddd,stroke:#cc0000,stroke-width:2px,color:#990000;
      class ELAPP,ELHDR,CSSH src;
      class UNB,EXT bad;
      linkStyle 0,1,2,3 stroke:#00aa00,stroke-width:2px;
      linkStyle 4,5,6,7 stroke:#cc0000,stroke-width:2px;

