@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Clock" ;
  ui:icon "🕐" ;
  schema:url </node_modules/sol-components/web/sol-time.js> ;
  dct:conformsTo </node_modules/sol-components/shapes/time-settings.shacl> ;
  dct:references </node_modules/sol-components/data/time-settings.ttl> ;
  schema:description "Clock widget (timezone in its settings file)." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Information" ;
  schema:additionalProperty
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/time/time-settings.ttl#Settings" ] .
