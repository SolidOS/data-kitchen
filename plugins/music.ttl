@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Component ;
  ui:label "Music (Internet Archive)" ;
  ui:icon "🎵" ;
  ui:name "ia-player" ;
  rdfs:comment "Browse and play music collections from the Internet Archive." ;
  dct:creator "Jeff Zucker" ;
  dct:subject "Media" ;
  ui:attribute
    [ schema:name "storage-ns" ; schema:value "music" ] ,
    [ schema:name "defer" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/ia-player/libraries/internet_archive_music/index.ttl" ] .
