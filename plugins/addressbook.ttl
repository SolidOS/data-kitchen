@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "SolidOS AddressBook" ;
  ui:icon "📇" ;
  schema:url </dk-pod/dk/plugins/solidos/dk-solidos.js> ;
  schema:description "Your contacts — a Solid address book, in the SolidOS contacts pane." ;
  dct:publisher "SolidOS Team" ;
  dct:subject "SolidOS apps" ;
  ui:attribute
    [ schema:name "source" ; schema:value "/dk-pod/contacts/index.ttl#this" ] ,
    [ schema:name "defer" ; schema:value "" ] .
