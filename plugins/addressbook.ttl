@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Component ;
  ui:label "Address Book" ;
  ui:icon "📇" ;
  ui:name "dk-solidos" ;
  rdfs:comment "Your contacts — a Solid address book, in the SolidOS contacts pane." ;
  dct:creator "SolidOS Team" ;
  dct:subject "Information" ;
  ui:attribute
    [ schema:name "source" ; schema:value "/dk-pod/contacts/index.ttl#this" ] ,
    [ schema:name "defer" ; schema:value "" ] .
