@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Component ;
  ui:label "Weather" ;
  ui:icon "🌤" ;
  ui:name "sol-weather" ;
  rdfs:comment "Weather widget (location and units in its settings file)." ;
  dct:creator "Jeff Zucker" ;
  dct:subject "Information" ;
  ui:attribute
    [ schema:name "source" ; schema:value "./plugins/weather/weather-settings.ttl#Settings" ] .
