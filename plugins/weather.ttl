@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Weather" ;
  ui:icon "🌤" ;
  schema:url </node_modules/sol-components/web/sol-weather.js> ;
  dct:conformsTo </node_modules/sol-components/shapes/weather-settings.shacl> ;
  dct:references </node_modules/sol-components/data/weather-settings.ttl> ;
  schema:description "Weather widget (location and units in its settings file)." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Information" ;
  ui:attribute
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/weather/weather-settings.ttl#Settings" ] .
