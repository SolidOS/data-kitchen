@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Data Kitchen Pod Browser" ;
  ui:icon "/assets/dk-logo.png" ;
  schema:url </dk-pod/dk/plugins/podz/dk-podz.js> ;
  schema:description "Browse and manage your Solid pods and workspaces." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Pods" ;
  ui:attribute
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/podz/dk-podz.html" ] ,
    [ schema:name "defer" ; schema:value "" ] .
