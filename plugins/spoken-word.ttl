@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Spoken Word (Internet Archive)" ;
  ui:icon "🎙️" ;
  schema:url </node_modules/open-media-player/dist/ia-player.esm.js> ;
  schema:description "Browse and play poetry, audiobooks, and talks from the Internet Archive." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Media" ;
  schema:additionalProperty
    [ schema:name "storage-ns" ; schema:value "spoken-word" ] ,
    [ schema:name "defer" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/ia-player/libraries/internet_archive_spoken_word/index.ttl" ] .
