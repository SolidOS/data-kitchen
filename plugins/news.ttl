@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "News (three-panel feeds)" ;
  ui:icon "📰" ;
  schema:url </node_modules/sol-components/web/sol-feed.js> ;
  schema:description "Read news feeds in a three-panel reader: sources, headlines, article." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Information" ;
  ui:attribute
    [ schema:name "view" ; schema:value "threePanel" ] ,
    [ schema:name "reader" ; schema:value "inline" ] ,
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/news/feeds.ttl#Feeds" ] .
