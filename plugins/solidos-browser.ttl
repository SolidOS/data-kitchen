@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "SolidOS (data browser)" ;
  ui:icon "https://solidproject.org/assets/img/solid-emblem.svg" ;
  schema:url </dk-pod/dk/plugins/solidos/dk-solidos.js> ;
  schema:description "The SolidOS data browser, embedded." ;
  dct:publisher "SolidOS Team" ;
  schema:keywords "Pods" ;
  ui:attribute
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/solidos/dk-solidos.html" ] ,
    [ schema:name "has-location-bar" ; schema:value "true" ] ,
    [ schema:name "defer" ; schema:value "" ] .
