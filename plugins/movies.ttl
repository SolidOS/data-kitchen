@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Movies (Internet Archive)" ;
  ui:icon "🎬" ;
  schema:url </node_modules/open-media-player/dist/ia-player.esm.js> ;
  schema:description "Browse and play films from the Internet Archive." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Media" ;
  ui:attribute
    [ schema:name "storage-ns" ; schema:value "movies" ] ,
    [ schema:name "favourites-only" ; schema:value "" ] ,
    [ schema:name "defer" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/ia-player/libraries/internet_archive_movies/index.ttl" ] .
