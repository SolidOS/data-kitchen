@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "SolidOS Meeting" ;
  ui:icon "🤝" ;
  schema:url </dk-pod/dk/plugins/solidos/dk-solidos.js> ;
  schema:description "A Solid meeting workspace, in the SolidOS meeting pane." ;
  dct:publisher "SolidOS Team" ;
  schema:keywords "SolidOS apps" ;
  ui:attribute
    [ schema:name "source" ; schema:value "/dk-pod/meetings/index.ttl#this" ] ,
    [ schema:name "defer" ; schema:value "" ] .
