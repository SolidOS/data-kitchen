@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "SolidOS Tasks" ;
  ui:icon "📋" ;
  schema:url </dk-pod/dk/plugins/solidos/dk-solidos.js> ;
  schema:description "Your tasks — a Solid issue tracker, in the SolidOS tracker pane." ;
  dct:publisher "SolidOS Team" ;
  schema:keywords "SolidOS apps" ;
  schema:additionalProperty
    [ schema:name "source" ; schema:value "/dk-pod/tasks/index.ttl#this" ] ,
    [ schema:name "defer" ; schema:value "" ] .
