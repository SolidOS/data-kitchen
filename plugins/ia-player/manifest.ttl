@prefix :       <#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .
@prefix acl:    <http://www.w3.org/ns/auth/acl#> .

<>
  a ui:Component ;
  ui:label "Internet Archive player" ;
  ui:name "ia-player" ;
  dct:creator "Jeff Zucker" ;
  dct:hasPart <./ia3.js> , <./ia-ui.js> , <./ia-rdf.js> ,
              <./assets/ia-player-shell.html> , <./assets/ia.css> ;
  dct:requires <./libraries/internet_archive_music/index.ttl> ,
               <./libraries/internet_archive_movies/index.ttl> ;
  schema:softwareHelp <./assets/ia-help.html> ;
  dct:conformsTo <../../shapes/music.shacl> ;
  dct:subject "Media" .

# ☰ contributions while an ia-player tab is active. Bare ui:name values are
# sol-commands, routed by the shell to the active panel's appAction().
<#Menu> a ui:Menu ; ui:label "Player" ;
  ui:parts ( <#Filters> <#ViewDeleted> <#InstallPod> <#UpdateApp> ) .

<#Filters> a ui:Component ; ui:label "Filters…" ; ui:name "filters" ;
  acl:mode acl:Write .
<#ViewDeleted> a ui:Component ; ui:label "View deleted" ; ui:name "viewDeleted" ;
  acl:mode acl:Write .
<#InstallPod> a ui:Component ; ui:label "Install on my Pod…" ; ui:name "installPod" ;
  acl:mode acl:Write .
<#UpdateApp> a ui:Component ; ui:label "Update app on Pod…" ; ui:name "updateApp" ;
  acl:mode acl:Write .
