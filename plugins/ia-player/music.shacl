# SHACL (Turtle) — the Turtle encoding of music.shaclc; keep the two in
# sync. See music.shaclc's header for the model rationale: a Release
# (mo:Release, tracks via the unordered mo:track set + intrinsic
# mo:track_number) and a Playlist (schema:ItemList + schema:MusicPlaylist,
# tracks via the ordered schema:itemListElement → schema:ListItem
# sequence) are deliberately DIFFERENT structures. A Release is NOT a
# schema:ItemList. Phase A and Phase B shipped 2026-05-21 — a Track
# links its audio file(s) via mo:item (multi-valued; Music Ontology
# sub-property of mo:available_as, "the full track").

@prefix : <#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix mo: <http://purl.org/ontology/mo/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix schema: <http://schema.org/> .
@prefix oa: <http://www.w3.org/ns/oa#> .

:GenreSchemeShape a sh:NodeShape ;
    sh:targetClass skos:ConceptScheme ;
    sh:property [ sh:path skos:prefLabel ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] .

:GenreShape a sh:NodeShape ;
    sh:targetClass skos:Concept ;
    sh:property [ sh:path rdf:type ; sh:hasValue mo:Genre ] ;
    sh:property [ sh:path skos:prefLabel ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path skos:topConceptOf ; sh:node :GenreSchemeShape ; sh:maxCount 1 ] .

:AgentShape a sh:NodeShape ;
    sh:targetClass foaf:Agent ;
    sh:property [ sh:path foaf:name ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path mo:genre ; sh:node :GenreShape ] ;
    sh:property [ sh:path dcat:landingPage ; sh:nodeKind sh:IRI ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:source ; sh:node :PlaylistShape ; sh:maxCount 1 ] .

:CatalogShape a sh:NodeShape ;
    sh:targetClass dcat:Catalog ;
    sh:property [ sh:path dcterms:title ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcat:catalog ; sh:node :CatalogShape ] ;
    sh:property [ sh:path dcat:dataset ; sh:nodeKind sh:IRI ] ;
    sh:property [ sh:path dcat:themeTaxonomy ; sh:node :GenreSchemeShape ; sh:maxCount 1 ] .

# Release — mo:Release (+ dcat:Dataset). Tracks are the unordered
# mo:track set; order is each Track's mo:track_number. NOT a
# schema:ItemList.
:ReleaseShape a sh:NodeShape ;
    sh:targetClass mo:Release ;
    sh:property [ sh:path rdf:type ; sh:hasValue dcat:Dataset ] ;
    sh:property [ sh:path dcterms:title ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:identifier ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:isPartOf ; sh:node :CatalogShape ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path foaf:maker ; sh:node :AgentShape ] ;
    sh:property [ sh:path mo:genre ; sh:node :GenreShape ] ;
    sh:property [ sh:path dcat:landingPage ; sh:nodeKind sh:IRI ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:date ; sh:datatype xsd:string ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:rights ; sh:datatype xsd:string ; sh:maxCount 1 ] ;
    sh:property [ sh:path foaf:depiction ; sh:nodeKind sh:IRI ] ;
    sh:property [ sh:path schema:ratingValue ; sh:datatype xsd:decimal ; sh:maxCount 1 ] ;
    sh:property [ sh:path rdfs:comment ; sh:datatype xsd:string ; sh:maxCount 1 ] ;
    sh:property [ sh:path mo:track ; sh:node :TrackShape ; sh:minCount 1 ] .

# Playlist — schema:ItemList + schema:MusicPlaylist (+ dcat:Dataset).
# Tracks are the ordered schema:itemListElement → schema:ListItem
# sequence. foaf:maker here is a literal curator name.
:PlaylistShape a sh:NodeShape ;
    sh:targetClass schema:MusicPlaylist ;
    sh:property [ sh:path rdf:type ; sh:hasValue schema:ItemList ] ;
    sh:property [ sh:path rdf:type ; sh:hasValue dcat:Dataset ] ;
    sh:property [ sh:path dcterms:title ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:isPartOf ; sh:node :CatalogShape ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path schema:itemListOrder ; sh:hasValue schema:ItemListOrderAscending ] ;
    sh:property [ sh:path foaf:maker ; sh:datatype xsd:string ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:description ; sh:datatype xsd:string ; sh:maxCount 1 ] ;
    sh:property [ sh:path oa:styleClass ; sh:datatype xsd:string ; sh:maxCount 1 ] ;
    sh:property [ sh:path schema:itemListElement ; sh:node :ListItemShape ] .

# ListItem — one ordered slot in a Playlist (schema:ListItem).
:ListItemShape a sh:NodeShape ;
    sh:targetClass schema:ListItem ;
    sh:property [ sh:path schema:position ; sh:datatype xsd:integer ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path schema:item ; sh:node :TrackShape ; sh:minCount 1 ; sh:maxCount 1 ] .

# Track — mo:Track, defined in its Release document. dcterms:isPartOf →
# the owning Release. The audio file(s) are linked via mo:item
# (multi-valued).
:TrackShape a sh:NodeShape ;
    sh:targetClass mo:Track ;
    sh:property [ sh:path dcterms:title ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:isPartOf ; sh:node :ReleaseShape ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path foaf:maker ; sh:node :AgentShape ] ;
    sh:property [ sh:path mo:track_number ; sh:datatype xsd:integer ; sh:maxCount 1 ] ;
    sh:property [ sh:path mo:duration ; sh:datatype xsd:decimal ; sh:maxCount 1 ] ;
    sh:property [ sh:path mo:bpm ; sh:datatype xsd:decimal ; sh:maxCount 1 ] ;
    sh:property [ sh:path schema:ratingValue ; sh:datatype xsd:decimal ; sh:maxCount 1 ] ;
    sh:property [ sh:path mo:item ; sh:nodeKind sh:IRI ] .
