{
  "@context": {
    "@version": 1.1,
    "ui": "http://www.w3.org/ns/ui#",
    "dct": "http://purl.org/dc/terms/",
    "schema": "http://schema.org/",
    "acl": "http://www.w3.org/ns/auth/acl#",
    "Component": "ui:Component",
    "Menu": "ui:Menu",
    "label": "ui:label",
    "name": "ui:name",
    "creator": "dct:creator",
    "subject": "dct:subject",
    "hasPart": {
      "@id": "dct:hasPart",
      "@type": "@id"
    },
    "requires": {
      "@id": "dct:requires",
      "@type": "@id"
    },
    "shape": {
      "@id": "dct:conformsTo",
      "@type": "@id"
    },
    "help": {
      "@id": "schema:softwareHelp",
      "@type": "@id"
    },
    "mode": {
      "@id": "acl:mode",
      "@type": "@id"
    },
    "parts": {
      "@id": "ui:parts",
      "@container": "@list",
      "@type": "@id"
    },
    "icon": "ui:icon"
  },
  "@id": "",
  "@type": "Component",
  "label": "Internet Archive player",
  "name": "ia-player",
  "creator": "Jeff Zucker",
  "hasPart": [
    "./ia3.js",
    "./ia-ui.js",
    "./ia-rdf.js",
    "./assets/ia-player-shell.html",
    "./assets/ia.css"
  ],
  "requires": [
    "./libraries/internet_archive_music/index.ttl",
    "./libraries/internet_archive_movies/index.ttl",
    "./libraries/internet_archive_spoken_word/index.ttl"
  ],
  "help": "./assets/ia-help.html",
  "shape": "./music.shacl",
  "subject": "Media",
  "@included": [
    {
      "@id": "#Menu",
      "@type": "Menu",
      "label": "Player",
      "parts": [
        {
          "@id": "#Filters",
          "@type": "Component",
          "label": "Filters…",
          "name": "filters",
          "mode": "acl:Write"
        },
        {
          "@id": "#ViewDeleted",
          "@type": "Component",
          "label": "View deleted",
          "name": "viewDeleted",
          "mode": "acl:Write"
        },
        {
          "@id": "#ImportMusic",
          "@type": "Component",
          "label": "Import music folder…",
          "name": "importMusic",
          "mode": "acl:Write"
        },
        {
          "@id": "#InstallPod",
          "@type": "Component",
          "label": "Install on my Pod…",
          "name": "installPod",
          "mode": "acl:Write"
        },
        {
          "@id": "#UpdateApp",
          "@type": "Component",
          "label": "Update app on Pod…",
          "name": "updateApp",
          "mode": "acl:Write"
        }
      ]
    }
  ],
  "icon": "🎵"
}
