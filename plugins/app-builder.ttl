@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "App Builder" ;
  ui:icon "🏗️" ;
  schema:url </node_modules/sol-components/web/sol-include.js> ;
  schema:description "Build your own app: pick a layout, add menus and plugins, publish to your pod." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "UI Controls" ;
  schema:additionalProperty
    [ schema:name "if-logged-in" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./dk-pod/dk/pages/app-builder.html" ] ,
    [ schema:name "trusted" ; schema:value "" ] .
