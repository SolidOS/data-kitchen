@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Calendar" ;
  ui:icon "📅" ;
  schema:url </node_modules/sol-components/web/sol-button.js> ;
  dct:conformsTo </node_modules/sol-components/shapes/calendar-settings.shacl> ;
  dct:references </node_modules/sol-components/data/calendar-settings.ttl> ;
  schema:description "Pop-out month calendar for the button bar." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Information" ;
  schema:additionalProperty
    [ schema:name "data-handler" ; schema:value "sol-calendar" ] ,
    [ schema:name "hide-header" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/calendar/calendar-settings.ttl#All" ] .
