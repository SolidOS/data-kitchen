@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Component ;
  ui:label "Calendar" ;
  ui:icon "📅" ;
  ui:name "sol-button" ;
  ui:region ui:Dropdown ;
  rdfs:comment "Pop-out month calendar for the button bar." ;
  dct:creator "Jeff Zucker" ;
  dct:subject "Information" ;
  ui:attribute
    [ schema:name "data-handler" ; schema:value "sol-calendar" ] ,
    [ schema:name "hide-header" ; schema:value "" ] ,
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/calendar/calendar-settings.ttl#All" ] .
