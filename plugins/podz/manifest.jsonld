{
  "@context": {
    "@version": 1.1,
    "ui": "http://www.w3.org/ns/ui#",
    "dct": "http://purl.org/dc/terms/",
    "schema": "http://schema.org/",
    "acl": "http://www.w3.org/ns/auth/acl#",
    "Component": "ui:Component",
    "Menu": "ui:Menu",
    "label": "ui:label",
    "name": "ui:name",
    "creator": "dct:creator",
    "subject": "dct:subject",
    "hasPart": { "@id": "dct:hasPart", "@type": "@id" },
    "requires": { "@id": "dct:requires", "@type": "@id" },
    "shape": { "@id": "dct:conformsTo", "@type": "@id" },
    "help": { "@id": "schema:softwareHelp", "@type": "@id" },
    "mode": { "@id": "acl:mode", "@type": "@id" },
    "parts": { "@id": "ui:parts", "@container": "@list", "@type": "@id" }
  },
  "@id": "",
  "@type": "Component",
  "label": "Data Kitchen Pod Browser",
  "name": "dk-podz",
  "creator": "Jeff Zucker",
  "hasPart": [
    "./dk-podz.html", "./dk-podz.js",
    "./podz.js", "./podz-ui.js", "./podz-state.js",
    "./podz-auth.js", "./podz-pod.js", "./podz-utils.js",
    "./podz.css", "./popup-auth-callback.html"
  ],
  "requires": ["./pod-settings.ttl"],
  "shape": "/node_modules/sol-components/shapes/pod-settings.shacl",
  "help": "./help.html",
  "subject": "Tech"
}
