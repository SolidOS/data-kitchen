@prefix ui:   <http://www.w3.org/ns/ui#> .
@prefix wd:   <http://www.wikidata.org/entity/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix :     <#> .

# sol-pod's single settings document — owned by the sol-pod component.
# Holds both the hide-path filters (ui:ignorePattern) the pod browser applies
# and the live-editor keybinding mode (ui:editorKeys) that sol-live-edit
# inherits. The central Settings page edits ONLY the hide paths (via
# pod-settings.shacl — the "Browser ignore paths" group); ui:editorKeys is
# the live editor's own concern, managed and pushed back here by the plugin
# itself.
<> a wd:Q1193846 ;
   foaf:primaryTopic <#Settings> .

<#Settings>
  ui:ignorePattern ".*", "*~", "#*#" ;
  ui:editorKeys ui:DefaultKeys .
