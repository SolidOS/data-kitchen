@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Search" ;
  schema:description "Search box for the button bar (pluggable search engines)." ;
  ui:icon "🔍" ;
  schema:url </node_modules/sol-components/web/sol-search.js> ;
  dct:conformsTo </node_modules/sol-components/shapes/search-engines.shacl> ;
  dct:references </node_modules/sol-components/data/search-engines.ttl> ;
    dct:publisher "Jeff Zucker" ;
  schema:keywords "Information" ;
  schema:additionalProperty
    [ schema:name "source" ; schema:value "./dk-pod/dk/plugins/search/search-engines.ttl#SearchEngines" ] .
