@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Component ;
  ui:label "SolidOS Notes" ;
  ui:icon "📝" ;
  ui:name "dk-solidos" ;
  rdfs:comment "A Solid notepad, in the SolidOS pad pane." ;
  dct:creator "SolidOS Team" ;
  dct:subject "SolidOS apps" ;
  ui:attribute
    [ schema:name "source" ; schema:value "/dk-pod/notes/index.ttl#this" ] ,
    [ schema:name "defer" ; schema:value "" ] .
