@prefix dct:    <http://purl.org/dc/terms/> .
@prefix ui:     <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

<>
  a ui:Plugin ;
  schema:additionalType ui:Component ;
  ui:label "Sign in" ;
  ui:icon "🔑" ;
  schema:url </node_modules/sol-components/web/sol-login.js> ;
  schema:description "Solid sign-in button (popup flow)." ;
  dct:publisher "Jeff Zucker" ;
  schema:keywords "Pods" ;
  ui:attribute
    [ schema:name "mode" ; schema:value "popup" ] .
