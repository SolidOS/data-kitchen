@prefix : <./genres.ttl#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.

<#FilmTypes> a skos:ConceptScheme; skos:prefLabel "Film Types".
<#Feature_Films> a skos:Concept; skos:prefLabel "Feature Films"; skos:topConceptOf <#FilmTypes>.
<#International_Films> a skos:Concept; skos:prefLabel "International Films"; skos:topConceptOf <#FilmTypes>.
<#Animation_TV_Shorts> a skos:Concept; skos:prefLabel "Animation, TV & Shorts"; skos:topConceptOf <#FilmTypes>.
<#Culture_Ethnicity> a skos:Concept; skos:prefLabel "Culture & Identity"; skos:topConceptOf <#FilmTypes>.
<#Ideas> a skos:Concept; skos:prefLabel "Ideas"; skos:topConceptOf <#FilmTypes>.
<#Art> a skos:Concept; skos:prefLabel "Art"; skos:topConceptOf <#FilmTypes>.
<#Museums> a skos:Concept; skos:prefLabel "Museums"; skos:topConceptOf <#FilmTypes>.
<#Social_Issues> a skos:Concept; skos:prefLabel "Social Issues"; skos:topConceptOf <#FilmTypes>.
